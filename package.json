{
  "name": "suiyuecare-finance",
  "version": "3.0.0",
  "private": true,
  "description": "歲悅長照集團財務管理系統 V3",
  "scripts": {
    "build": "rm -rf www && mkdir -p www && cp index.html manifest.webmanifest sw.js www/ && cp -R assets docs www/",
    "cap:sync": "pnpm build && cap sync",
    "cap:open:ios": "pnpm cap:sync && cap open ios",
    "cap:open:android": "pnpm cap:sync && cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.4.4",
    "@capacitor/ios": "^7.4.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.4"
  }
}
